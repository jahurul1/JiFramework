# JiFramework .gitignore

# AI / dev memory
.jidev/
memory/

# Logs
*.log
storage/Logs/*
!storage/Logs/.gitkeep

# Databases
*.sqlite
*.sqlite3
*.db
storage/RateLimit/*
!storage/RateLimit/.gitkeep

# Cache
storage/Cache/*
!storage/Cache/.gitkeep

# User uploaded files
storage/Uploads/*
!storage/Uploads/.gitkeep

# Access control runtime data
storage/AccessControl/*
!storage/AccessControl/.gitkeep

# User config (copy jiconfig.example.php → jiconfig.php and fill in your values)
jiconfig.php
config/jiconfig.php

# Environment configuration
.env
.env.local
.env.*.local

# Composer dependencies
/vendor/
composer.lock

# Test project (local dev only)
/TestProject/

# PHPUnit artifacts
.phpunit.result.cache
test-results/
coverage/
*coverage.xml

# Build artifacts
/build/
/dist/

# Temporary files
*.tmp
*.bak
*.cache
/tmp/

# Editors
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Node.js
/node_modules/
npm-debug.log
yarn-error.log
package-lock.json
yarn.lock
